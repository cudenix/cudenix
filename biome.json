{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedEnumMembers": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on",
				"useSortedPackageJson": "on"
			}
		}
	},
	"files": { "ignoreUnknown": true, "includes": ["**/*.json", "**/*.ts*"] },
	"formatter": {
		"enabled": true,
		"expand": "never",
		"indentStyle": "tab",
		"indentWidth": 4
	},
	"javascript": { "formatter": { "quoteStyle": "double" } },
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": { "recommended": true },
			"complexity": {
				"noUselessUndefined": "error",
				"recommended": true
			},
			"correctness": { "recommended": true },
			"nursery": { "recommended": true },
			"performance": { "recommended": true },
			"security": { "recommended": true },
			"style": {
				"noUnusedTemplateLiteral": "error",
				"noUselessElse": "error",
				"noYodaExpression": "error",
				"recommended": true,
				"useBlockStatements": "error",
				"useConsistentArrowReturn": "error",
				"useConsistentTypeDefinitions": {
					"level": "error",
					"options": { "style": "interface" }
				},
				"useShorthandAssign": "error"
			},
			"suspicious": {
				"noShadowRestrictedNames": "info",
				"recommended": true
			}
		}
	},
	"vcs": { "clientKind": "git", "enabled": true, "useIgnoreFile": true }
}
