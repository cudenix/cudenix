{
	"name": "@cudenix/cudenix",
	"version": "0.0.65",
	"description": "cudenix",
	"keywords": [
		"api",
		"bun",
		"framework",
		"http",
		"server",
		"sse",
		"typescript",
		"web"
	],
	"homepage": "https://github.com/cudenix/cudenix",
	"bugs": {
		"url": "https://github.com/cudenix/cudenix/issues",
		"email": "security@cudenix.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cudenix/cudenix.git"
	},
	"license": "MIT",
	"author": "cudenix <contact@cudenix.com> (https://cudenix.com)",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
		"./client": {
			"types": "./dist/ecosystem/client/index.d.ts",
			"import": "./dist/ecosystem/client/index.js"
		},
		"./cluster": {
			"types": "./dist/ecosystem/plugins/cluster/index.d.ts",
			"import": "./dist/ecosystem/plugins/cluster/index.js"
		},
		"./compress": {
			"types": "./dist/ecosystem/plugins/compress/index.d.ts",
			"import": "./dist/ecosystem/plugins/compress/index.js"
		},
		"./cors": {
			"types": "./dist/ecosystem/plugins/cors/index.d.ts",
			"import": "./dist/ecosystem/plugins/cors/index.js"
		},
		"./events": {
			"types": "./dist/ecosystem/plugins/events/index.d.ts",
			"import": "./dist/ecosystem/plugins/events/index.js"
		},
		"./global-request-context": {
			"types": "./dist/ecosystem/plugins/global-request-context/index.d.ts",
			"import": "./dist/ecosystem/plugins/global-request-context/index.js"
		},
		"./i18n": {
			"types": "./dist/ecosystem/plugins/i18n/index.d.ts",
			"import": "./dist/ecosystem/plugins/i18n/index.js"
		},
		"./openapi": {
			"types": "./dist/ecosystem/plugins/openapi/index.d.ts",
			"import": "./dist/ecosystem/plugins/openapi/index.js"
		},
		"./package.json": "./package.json",
		"./standard-schema": {
			"types": "./dist/ecosystem/plugins/standard-schema/index.d.ts",
			"import": "./dist/ecosystem/plugins/standard-schema/index.js"
		},
		"./try-catch": {
			"types": "./dist/ecosystem/plugins/try-catch/index.d.ts",
			"import": "./dist/ecosystem/plugins/try-catch/index.js"
		}
	},
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "bun --bun check && tsc --checkers 8 && tsc-alias",
		"check": "biome check --diagnostic-level=error --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "bun --bun test --coverage && bun --bun run typecheck",
		"typecheck": "tsc --build tsconfig.json tests/tsconfig.json --noEmit --builders 8 --checkers 8"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/bun": "1.3.14",
		"mitata": "1.0.34",
		"tsc-alias": "1.9.0",
		"typescript": "7.0.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"trustedDependencies": []
}
