{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"endOfLine": "lf",
	"ignorePatterns": ["dist", "node_modules"],
	"printWidth": 100,
	"semi": true,
	"singleAttributePerLine": true,
	"singleQuote": false,
	"sortImports": true,
	"sortPackageJson": true,
	"sortTailwindcss": true,
	"tabWidth": 4,
	"trailingComma": "all",
	"useTabs": true
}
